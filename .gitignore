# Python
__pycache__/
*.py[cod]
.venv/
.venv*/
venv/
*.egg-info/
.pytest_cache/
build/
dist/

# Vendored GAM7 binary — fetched via scripts/fetch_gam.sh, never committed
gamgui/resources/gam7/*
!gamgui/resources/gam7/.gitkeep
!gamgui/resources/gam7/VERSION
# …but the derived command catalog IS committed (small, powers the Builder + contract test)
!gamgui/resources/gam7/command_catalog.json

# Secrets / local runtime state must never be committed
*.oauth2service.json
oauth2.txt
client_secrets.json
*.local
.gamgui/

# Local editor / agent tooling state: settings stay local; shared skills/agents are tracked.
.claude/*
!.claude/skills/
!.claude/agents/

# macOS
.DS_Store
